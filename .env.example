# Supabase
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# App Config
VITE_APP_NAME=AquaSpin Rewards
VITE_APP_URL=http://localhost:5173

# Ad Network Keys (replace with real keys before production)
VITE_APPLOVIN_SDK_KEY=your-applovin-sdk-key
VITE_ADSENSE_CLIENT_ID=ca-pub-your-publisher-id
VITE_PROPELLERADS_ZONE_ID=your-zone-id

# Feature Flags (set to 'true' or 'false')
VITE_MOCK_ADS=true
VITE_ENABLE_GUEST_PLAY=true
VITE_SPIN_COOLDOWN_SECONDS=30
